{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devops-concierge",
  "version": "0.1.0",
  "identifier": "com.devopsconcierge.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "DevOps Concierge Agent",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/backend",
      "binaries/scheduler"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
